# Example environment variables for the server
# Copy this file to `server/.env` and fill in real values.
PORT=5000
NODE_ENV=development
MONGO_URI=your_mongodb_connection_string_here
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d
CLIENT_URL=http://localhost:3000  # URL of the React app (dev server typically runs on 3000)
